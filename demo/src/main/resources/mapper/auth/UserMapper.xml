<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.domain.auth.repository.mybatis.UserAuthDAO">

    <select id="findByEmail" parameterType="java.lang.String" resultType="com.project.domain.auth.entity.Users">
        SELECT 
            id, 
            email, 
            password, 
            provider, 
            provider_id, 
            created_at
        FROM users
        WHERE email = #{email}
    </select>

</mapper>