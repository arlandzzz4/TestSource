<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
 
<mapper namespace="com.project.iob.postwrite.service.repository.mybatis.PostWriteDAO">
 
    <!-- 게시글 등록 -->
    <insert id="insert">
        INSERT INTO posts (
            user_email,
            category_code,
            title,
            content,
            del_yn,
            created_at
        ) VALUES (
            #{dto.userEmail},
            #{dto.categoryCode},
            #{dto.title},
            #{dto.content},
            'N',
            NOW()
        )
    </insert>
 
</mapper>
 